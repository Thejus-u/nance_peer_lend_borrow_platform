DJANGO_ENV=local
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

DATABASE_URL=postgres://peer_user:peer_pass@db:5432/peer_platform
DB_CONN_MAX_AGE=60

REDIS_URL=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

DRF_THROTTLE_ANON=60/minute
DRF_THROTTLE_USER=120/minute

CELERY_TASK_ALWAYS_EAGER=False

LOG_LEVEL=INFO

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_TOKEN_URL=https://oauth2.googleapis.com/token
GMAIL_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo
GMAIL_MESSAGES_LIST_URL=https://gmail.googleapis.com/gmail/v1/users/me/messages
GMAIL_MESSAGES_GET_URL=https://gmail.googleapis.com/gmail/v1/users/me/messages
